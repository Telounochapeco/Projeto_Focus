{
  "manifest_version": 3,
  "name": "FocusFlow",
  "description": "Extensão para bloquear distrações durante os estudos",
  "version": "1.0",

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "storage",
    "declarativeNetRequest"
  ],

  "host_permissions": [
    "*://*.facebook.com/*",
    "*://*.instagram.com/*",
    "*://*.youtube.com/*"
  ]
}